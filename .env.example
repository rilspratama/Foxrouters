# AI Gateway environment configuration.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#
# In docker-compose, REDIS_ADDR / CLICKHOUSE_ADDR / PORT are overridden
# with container DNS names, so the values below are for bare-metal runs.

# ---------------------------------------------------------------------------
# Redis (hot state: tokens, CB credits, disabled flags, gateway keys, rate)
# ---------------------------------------------------------------------------
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# Log backend (request/response history for /history* endpoints)
# ---------------------------------------------------------------------------
#   LOG_BACKEND=sqlite      (default) → embedded modernc.org/sqlite, ~0 ops cost
#   LOG_BACKEND=clickhouse            → external ClickHouse (analytics)
#
# SQLite stores the DB file at LOG_SQLITE_PATH (default below). Persist this
# path across container restarts by mounting a docker volume onto it.
# ---------------------------------------------------------------------------
LOG_BACKEND=sqlite
LOG_SQLITE_PATH=/var/lib/foxrouters/logs.db

# ---------------------------------------------------------------------------
# ClickHouse (only used when LOG_BACKEND=clickhouse — full request/response
# JSON, 90d TTL, analytics-optimised). Native protocol port 9000, NOT HTTP.
# Database auto-created on first boot if missing.
# ---------------------------------------------------------------------------
CLICKHOUSE_ADDR=127.0.0.1:9000
CLICKHOUSE_DB=foxrouters
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
PORT=20130

# ---------------------------------------------------------------------------
# Bootstrap credentials (first-run seed only — persisted to Redis after)
# After first boot, Redis is the single source of truth and these are unused.
# Leave empty to manage credentials via REST API instead.
# ---------------------------------------------------------------------------
# GATEWAY_KEY_FILE=./gateway-key.txt
# GATEWAY_API_KEYS=            # comma-separated gateway keys
# CB_KEY_FILE=./codebuddy-key.txt
# CB_API_KEYS=                 # comma-separated CodeBuddy keys

# ---------------------------------------------------------------------------
# Dev override — set to `1` to disable Bearer auth on all endpoints.
# LEAVE EMPTY IN PRODUCTION.
# ---------------------------------------------------------------------------
GATEWAY_AUTH_DISABLE=

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (optional — expose the gateway to the public internet
# without opening a port on the host firewall).
#
#   none  (default) — no tunnel; gateway only reachable on 127.0.0.1:20130
#   quick           — random *.trycloudflare.com URL, no domain / no login
#   named           — persistent custom domain; requires prior `cloudflared
#                     tunnel login` + `create` + config at /etc/foxrouters/cloudflared/
#
# Read by install.sh for non-interactive installs, and by ./tunnel.sh.
# ---------------------------------------------------------------------------
TUNNEL_MODE=none

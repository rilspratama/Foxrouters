# Version control
.git
.gitignore
.gitattributes
.github

# Environment files & secrets — NEVER bake into image
*.env
.gateway.env
gateway-key.txt
bootstrap-key.txt
codebuddy-key.txt
codebuddy-key*.txt

# xAI account credential dumps
xai-*.json

# CodeBuddy auth files (mounted at runtime, not baked in)
cpa_auths/

# Pre-built binary from host (image builds its own)
foxrouters
ai-gateway
grok-gateway

# Dev / tooling artifacts
graphify-out/
migrate.py
stress_test.py
stress_test_v2.py
migration-backup/
*.tsv
*.rdb
*.tar.gz
*.zip
node_modules/
tmp/

# Docs (except README if present)
*.md
!README.md

# Editor / OS junk
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Test binaries / coverage
*.test
*.out
coverage.txt
